# Google Gemini API key (for extraction, categorization, chat, and scanned-PDF vision).
# If unset, Ollama is used for text/chat when available; vision is skipped.
# Get a key: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GEMINI_API_KEY=

# Optional: comma-separated frontend origins for CORS (e.g. https://your-app.vercel.app).
# If unset, localhost and default production origins are allowed.
# ALLOWED_ORIGINS=
