# Google Gemini API key (for extraction, categorization, chat, and scanned-PDF vision).
# If unset, Ollama is used for text/chat when available; vision is skipped.
# Get a key: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GEMINI_API_KEY=
DATALAB_API_KEY=
API_AUTH_SECRET=
# Supabase (auth + DB). Create a project at https://supabase.com
# IMPORTANT: Backend SUPABASE_URL must be the SAME as frontend VITE_SUPABASE_URL (same project).
# Project Settings → API: Project URL.
# JWT: set only SUPABASE_URL for JWKS (recommended); or set SUPABASE_JWT_SECRET for legacy HS256.
SUPABASE_URL=https://your-project-ref.supabase.co
# Optional. Set for legacy HS256; leave unset to use JWKS.
SUPABASE_JWT_SECRET=

# Database: Supabase → Project Settings → Database → Connection string.
# If "could not translate host name db.xxx.supabase.co" appears, use the Connection pooling (Transaction) URI instead of Direct; the pooler host (e.g. aws-0-xx.pooler.supabase.com) often resolves better on local networks.
DATABASE_URL=

# Optional: comma-separated frontend origins for CORS (e.g. https://your-app.vercel.app).
# If unset, localhost and default production origins are allowed.
ALLOWED_ORIGINS=