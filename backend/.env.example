# Google Gemini API key (for extraction, categorization, chat, and scanned-PDF vision).
# If unset, Ollama is used for text/chat when available; vision is skipped.
# Get a key: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GEMINI_API_KEY=
DATALAB_API_KEY=
API_AUTH_SECRET=
# Supabase (auth + DB). Create a project at https://supabase.com
# Project Settings → API: Project URL (required for JWKS or legacy).
# JWT verification: preferred = JWKS (set only SUPABASE_URL); legacy = set SUPABASE_JWT_SECRET too.
# Supabase has migrated to new JWT Signing Keys; the legacy secret is only for verifying JWTs and can be rotated via standby key.
SUPABASE_URL=https://your-project-ref.supabase.co
# Optional if using JWKS (new signing keys). Set for legacy HS256 verification.
SUPABASE_JWT_SECRET=

# Database: Supabase → Project Settings → Database → Connection string (use pooler for serverless).
DATABASE_URL=

# Optional: comma-separated frontend origins for CORS (e.g. https://your-app.vercel.app).
# If unset, localhost and default production origins are allowed.
ALLOWED_ORIGINS=